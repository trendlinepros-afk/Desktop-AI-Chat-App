{
  "appId": "com.wicked.app",
  "productName": "WICKED",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": ["dist", "dist-electron", "build/icon.png"],
  "asarUnpack": ["**/node_modules/better-sqlite3/**"],
  "publish": [
    {
      "provider": "github",
      "owner": "trendlinepros-afk",
      "repo": "desktop-ai-chat-app",
      "releaseType": "release"
    }
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.productivity",
    "icon": "build/icon.png",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "WICKED uses the microphone for voice chat and dictation."
    }
  },
  "win": {
    "target": ["nsis"],
    "icon": "build/icon.png"
  },
  "nsis": {
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "WICKED"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Utility",
    "icon": "build/icon.png"
  }
}
